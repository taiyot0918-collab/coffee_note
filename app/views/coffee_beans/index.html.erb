<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold text-amber-900">🫘 コーヒー豆</h1>
  <%= link_to "+ 新しい豆を追加", new_coffee_bean_path, class: "bg-amber-700 hover:bg-amber-800 text-white text-sm px-4 py-2 rounded-lg" %>
</div>

<% if @coffee_beans.any? %>
  <div class="grid gap-4">
    <% @coffee_beans.each do |bean| %>
      <div class="bg-white rounded-xl shadow-sm p-5 flex justify-between items-center">
        <div>
          <p class="font-semibold text-gray-800"><%= bean.name %></p>
          <p class="text-sm text-gray-500">産地: <%= bean.origin %> ／ 品種: <%= bean.variety %></p>
        </div>
        <div class="flex gap-3 text-sm">
          <%= link_to "詳細", bean, class: "text-amber-600 hover:underline" %>
          <%= link_to "編集", edit_coffee_bean_path(bean), class: "text-gray-400 hover:underline" %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <p class="text-gray-400">まだ登録されていません</p>
<% end %>