<%= link_to "← 一覧に戻る", brew_notes_path, class: "text-xs text-gray-400 hover:text-gray-700 transition mb-8 inline-block" %>

<div class="bg-white border border-gray-100 rounded-xl p-8">
  <h1 class="text-xl font-medium mb-6"><%= @brew_note.tool %></h1>

  <dl class="grid grid-cols-2 gap-y-5 text-sm">
    <div>
      <dt class="text-xs text-gray-400 mb-1">使用した豆</dt>
      <dd class="font-medium"><%= @brew_note.coffee_bean&.name.presence || "未設定" %></dd>
    </div>
    <div>
      <dt class="text-xs text-gray-400 mb-1">評価</dt>
      <dd class="font-medium"><%= @brew_note.rating.present? ? "#{@brew_note.rating}/5" : "未設定" %></dd>
    </div>
    <div>
      <dt class="text-xs text-gray-400 mb-1">豆量</dt>
      <dd class="font-medium"><%= @brew_note.dose.present? ? "#{@brew_note.dose}g" : "未設定" %></dd>
    </div>
    <div>
      <dt class="text-xs text-gray-400 mb-1">湯量</dt>
      <dd class="font-medium"><%= @brew_note.water_amount.present? ? "#{@brew_note.water_amount}ml" : "未設定" %></dd>
    </div>
    <div>
      <dt class="text-xs text-gray-400 mb-1">湯温</dt>
      <dd class="font-medium"><%= @brew_note.water_temp.present? ? "#{@brew_note.water_temp}℃" : "未設定" %></dd>
    </div>
    <div>
      <dt class="text-xs text-gray-400 mb-1">抽出時間</dt>
      <dd class="font-medium"><%= @brew_note.brew_time.present? ? "#{@brew_note.brew_time}秒" : "未設定" %></dd>
    </div>
  </dl>

  <% if @brew_note.taste_memo.present? %>
    <div class="border-t border-gray-100 mt-6 pt-6">
      <p class="text-xs text-gray-400 mb-2">味メモ</p>
      <p class="text-sm leading-relaxed"><%= @brew_note.taste_memo %></p>
    </div>
  <% end %>

  <div class="flex gap-5 mt-8 pt-6 border-t border-gray-100 text-xs">
    <%= link_to "編集", edit_brew_note_path(@brew_note), class: "text-gray-500 hover:text-gray-900 transition" %>
    <%= link_to "削除", @brew_note, data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" }, class: "text-red-400 hover:text-red-600 transition" %>
  </div>
</div>