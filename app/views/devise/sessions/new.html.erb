<div class="max-w-md mx-auto mt-16">
  <div class="bg-white rounded-2xl shadow-md p-8">

    <%# タイトル %>
    <h1 class="text-2xl font-bold text-amber-900 text-center mb-2">☕ Coffee Note</h1>
    <p class="text-center text-gray-400 text-sm mb-8">ログイン</p>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

      <%# エラーメッセージ %>
      <% if resource.errors.any? %>
        <div class="bg-red-50 text-red-600 text-sm rounded-lg p-3 mb-4">
          <%= resource.errors.full_messages.first %>
        </div>
      <% end %>

      <%# メールアドレス %>
      <div class="mb-4">
        <%= f.label :email, "メールアドレス", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "w-full border border-gray-300 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-400" %>
      </div>

      <%# パスワード %>
      <div class="mb-6">
        <%= f.label :password, "パスワード", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :password, autocomplete: "current-password",
            class: "w-full border border-gray-300 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-400" %>
      </div>

      <%# ログインボタン %>
      <%= f.submit "ログイン", class: "w-full bg-amber-700 hover:bg-amber-800 text-white font-semibold py-2 rounded-lg transition cursor-pointer" %>

    <% end %>

    <%# 新規登録リンク %>
    <p class="text-center text-sm text-gray-400 mt-6">
      アカウントをお持ちでない方は
      <%= link_to "新規登録", new_user_registration_path, class: "text-amber-600 hover:underline" %>
    </p>

  </div>
  <%# 区切り線 %>
  <div class="flex items-center gap-3 my-4">
    <hr class="flex-1 border-gray-200">
    <span class="text-xs text-gray-400">または</span>
    <hr class="flex-1 border-gray-200">
  </div>
              
  <%# ゲストログインボタン %>
  <%= button_to "ゲストユーザーでログイン", guest_sign_in_path,
      method: :post,
      class: "w-full border border-gray-300 text-gray-600 text-sm font-medium py-2 rounded-lg hover:bg-gray-50 transition cursor-pointer" %>
</div>