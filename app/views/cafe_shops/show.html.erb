<div class="bg-white rounded-xl shadow-sm p-6 max-w-lg">
  <h1 class="text-2xl font-bold text-amber-900 mb-4">☕ <%= @cafe_shop.name %></h1>

  <dl class="grid grid-cols-2 gap-4 text-sm">
    <div>
      <dt class="text-gray-400">住所</dt>
      <dd class="font-medium"><%= @cafe_shop.address %></dd>
    </div>
    <div>
      <dt class="text-gray-400">訪問日</dt>
      <dd class="font-medium"><%= @cafe_shop.visit_date %></dd>
    </div>
    <div>
      <dt class="text-gray-400">評価</dt>
      <dd class="font-medium"><%= @cafe_shop.rating %>/5</dd>
    </div>
  </dl>

  <% if @cafe_shop.memo.present? %>
    <div class="mt-4">
      <p class="text-gray-400 text-sm">メモ</p>
      <p class="text-sm mt-1"><%= @cafe_shop.memo %></p>
    </div>
  <% end %>

  <div class="flex gap-4 mt-6 text-sm">
    <%= link_to "編集", edit_cafe_shop_path(@cafe_shop), class: "text-amber-600 hover:underline" %>
    <%= link_to "削除", @cafe_shop, data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" }, class: "text-red-400 hover:underline" %>
    <%= link_to "← 一覧に戻る", cafe_shops_path, class: "text-gray-400 hover:underline" %>
  </div>
</div>