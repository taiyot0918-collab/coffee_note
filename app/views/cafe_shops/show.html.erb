<%= link_to "← 一覧に戻る", cafe_shops_path, class: "text-xs text-gray-400 hover:text-gray-700 transition mb-8 inline-block" %>

<div class="bg-white border border-gray-100 rounded-xl p-8">
  <h1 class="text-xl font-medium mb-6"><%= @cafe_shop.name %></h1>

  <dl class="grid grid-cols-2 gap-y-5 text-sm">
    <div>
      <dt class="text-xs text-gray-400 mb-1">住所</dt>
      <dd class="font-medium"><%= @cafe_shop.address.presence || "未登録" %></dd>
    </div>
    <div>
      <dt class="text-xs text-gray-400 mb-1">訪問日</dt>
      <dd class="font-medium">
        <%= @cafe_shop.visit_date.present? ? @cafe_shop.visit_date.strftime("%Y年%m月%d日") : "未登録" %>
      </dd>
    </div>
    <div>
      <dt class="text-xs text-gray-400 mb-1">評価</dt>
      <dd class="font-medium"><%= @cafe_shop.rating.present? ? "#{@cafe_shop.rating}/5" : "未登録" %></dd>
    </div>
  </dl>

  <% if @cafe_shop.memo.present? %>
    <div class="border-t border-gray-100 mt-6 pt-6">
      <p class="text-xs text-gray-400 mb-2">メモ</p>
      <p class="text-sm leading-relaxed"><%= @cafe_shop.memo %></p>
    </div>
  <% end %>

  <div class="flex gap-5 mt-8 pt-6 border-t border-gray-100 text-xs">
    <%= link_to "編集", edit_cafe_shop_path(@cafe_shop), class: "text-gray-500 hover:text-gray-900 transition" %>
    <%= link_to "削除", @cafe_shop, data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" }, class: "text-red-400 hover:text-red-600 transition" %>
  </div>
</div>