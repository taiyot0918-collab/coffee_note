<div class="flex justify-between items-end mb-10">
  <div>
    <h1 class="text-2xl font-medium">カフェ記録</h1>
    <p class="text-sm text-gray-400 mt-1"><%= @cafe_shops.count %>件登録済み</p>
  </div>
  <%= link_to "+ 新しいカフェを追加", new_cafe_shop_path, class: "bg-neutral-900 text-white text-xs px-4 py-2 rounded-lg hover:bg-neutral-700 transition" %>
</div>

<% if @cafe_shops.any? %>
  <% @cafe_shops.each do |cafe| %>
    <div class="bg-white border border-gray-100 hover:border-gray-300 rounded-xl px-5 py-4 mb-2 flex justify-between items-center transition">
      <div>
        <p class="text-sm font-medium"><%= cafe.name %></p>
        <p class="text-xs text-gray-400 mt-1">
          <%= cafe.address.presence || "住所未登録" %>
          <% if cafe.visit_date.present? %>
            · <%= cafe.visit_date.strftime("%Y年%m月%d日") %>
          <% end %>
        </p>
      </div>
      <div class="flex gap-4">
        <%= link_to "詳細 →", cafe, class: "text-xs text-gray-400 hover:text-gray-700 transition" %>
        <%= link_to "編集", edit_cafe_shop_path(cafe), class: "text-xs text-gray-400 hover:text-gray-700 transition" %>
      </div>
    </div>
  <% end %>
<% else %>
  <p class="text-sm text-gray-300">まだ登録されていません</p>
<% end %>